[Unit]
Description=ROV Turret IP Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ROV/backend
ExecStart=/usr/bin/python3 -u /home/pi/ROV/backend/turret_ip_monitor.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
